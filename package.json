{
  "name": "grok-search-cli",
  "version": "0.1.2",
  "description": "AI-friendly CLI for high-freshness web and X research with Grok search tool.",
  "keywords": [
    "agent",
    "agentic",
    "ai",
    "cli",
    "grok",
    "llm",
    "research",
    "search",
    "web-search",
    "x-search",
    "x",
    "xai",
    "freshness",
    "real-time",
    "github",
    "shell"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "grok-search": "dist/cli.js"
  },
  "files": [
    "agents",
    "dist",
    "skills",
    "README.md",
    "README.zh.md",
    ".env.example",
    ".env.openrouter.example",
    ".env.yunwu.example"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "dotenvx run -f .env -- tsx src/cli.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@ai-sdk/xai": "^3.0.77",
    "ai": "^6.0.145",
    "conf": "^14.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vite": "^8.0.3"
  }
}
